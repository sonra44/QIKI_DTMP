# M2: NATS bus authentication (F5 design §6), единый token-auth.
# Скопируй в .env и задай реальный токен: openssl rand -hex 24
# Без .env nats-server откажется стартовать (fail-closed).
NATS_TOKEN=CHANGE_ME

# M3: QIKI Gateway (LLM). Реальный ключ провайдера ТОЛЬКО тут.
OPENAI_API_KEY_REAL=CHANGE_ME_real_provider_key
QIKI_GATEWAY_VKEY_QCORE=vk-qcore-CHANGE_ME
QIKI_GATEWAY_MODE=audit
# OPENAI_UPSTREAM_URL=https://api.openai.com/v1
