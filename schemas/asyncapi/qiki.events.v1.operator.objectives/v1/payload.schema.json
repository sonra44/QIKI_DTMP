{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "qiki.events.v1.operator.objectives/v1/payload.schema.json",
  "title": "qiki.events.v1.operator.objectives payload (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_schema_version",
    "source",
    "subject",
    "timestamp",
    "ts_epoch",
    "kind",
    "objective_id",
    "objective_type",
    "status",
    "observation_style",
    "procedure_name",
    "route_role",
    "request_id",
    "proposal_id",
    "mode",
    "title_ru",
    "title_en",
    "summary_ru",
    "summary_en",
    "reason_code"
  ],
  "properties": {
    "event_schema_version": { "type": "integer", "const": 1 },
    "source": { "type": "string", "minLength": 1 },
    "subject": { "type": "string", "const": "qiki.events.v1.operator.objectives" },
    "timestamp": { "type": "string", "minLength": 1 },
    "ts_epoch": { "type": "number" },
    "kind": {
      "type": "string",
      "enum": ["observation_objective_seed", "observation_objective_update"]
    },
    "objective_id": { "type": "string", "minLength": 1 },
    "objective_type": { "type": "string", "const": "observation" },
    "status": { "type": "string", "enum": ["prepared", "confirmed", "failed", "cancelled"] },
    "observation_style": { "type": "string", "enum": ["safe", "slow"] },
    "procedure_name": { "type": "string", "minLength": 1 },
    "route_role": { "type": "string", "enum": ["official", "deviation"] },
    "request_id": { "type": "string", "minLength": 1 },
    "proposal_id": { "type": "string" },
    "mode": { "type": "string", "enum": ["FACTORY", "MISSION"] },
    "target_designator": { "type": ["string", "null"] },
    "track_visible": { "type": "boolean" },
    "track_id": { "type": ["string", "null"] },
    "track_label": { "type": ["string", "null"] },
    "track_range_m": { "type": ["number", "null"] },
    "track_quality": { "type": ["number", "null"] },
    "observation_result_status": { "type": ["string", "null"], "enum": ["reconfirmed", "signature_changed", null] },
    "observation_result_reason_code": { "type": ["string", "null"] },
    "observation_result_summary_en": { "type": ["string", "null"] },
    "observation_result_summary_ru": { "type": ["string", "null"] },
    "title_ru": { "type": "string" },
    "title_en": { "type": "string" },
    "summary_ru": { "type": "string" },
    "summary_en": { "type": "string" },
    "reason_code": { "type": "string" }
  }
}
