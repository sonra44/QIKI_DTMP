{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "qiki.responses.qiki/v1/payload.schema.json",
  "title": "qiki.responses.qiki payload (QikiChatResponse.v1)",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "request_id", "ok", "mode", "proposals", "warnings", "trust_signals"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "request_id": { "type": "string", "format": "uuid" },
    "ok": { "type": "boolean" },
    "mode": { "type": "string", "enum": ["FACTORY", "MISSION"] },
    "reply": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "title": { "$ref": "#/$defs/bilingual" },
        "body": { "$ref": "#/$defs/bilingual" }
      }
    },
    "legality": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "status": { "type": "string", "enum": ["allowed", "blocked", "deferred", "unsafe"] },
        "domain": { "type": "string", "enum": ["physics", "zone", "protocol", "resource", "trust", "unknown"] },
        "reason_code": { "type": "string" },
        "reason": { "$ref": "#/$defs/bilingual" },
        "allowed_when": { "oneOf": [{ "$ref": "#/$defs/bilingual" }, { "type": "null" }] }
      }
    },
    "trust_signals": {
      "type": "array",
      "items": { "$ref": "#/$defs/trust_signal" }
    },
    "consequence": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "status": { "type": "string", "enum": ["confirmed", "not_sent", "pending", "failed"] },
        "summary": { "$ref": "#/$defs/bilingual" },
        "telemetry_confirmation": { "oneOf": [{ "$ref": "#/$defs/bilingual" }, { "type": "null" }] }
      }
    },
    "proposals": {
      "type": "array",
      "items": { "$ref": "#/$defs/proposal" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/bilingual" }
    },
    "error": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "code": { "type": "string", "enum": ["TIMEOUT", "INVALID_REQUEST", "INTERNAL", "UNAVAILABLE"] },
        "message": { "$ref": "#/$defs/bilingual" }
      }
    }
  },
  "$defs": {
    "bilingual": {
      "type": "object",
      "additionalProperties": true,
      "required": ["en", "ru"],
      "properties": {
        "en": { "type": "string" },
        "ru": { "type": "string" }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "subject", "name", "parameters", "dry_run"],
      "properties": {
        "kind": { "type": "string", "enum": ["NATS_COMMAND", "ORION_PROCEDURE"] },
        "subject": { "type": "string" },
        "name": { "type": "string" },
        "parameters": { "type": "object" },
        "dry_run": { "type": "boolean" }
      }
    },
    "trust_signal": {
      "type": "object",
      "additionalProperties": true,
      "required": ["label", "state", "source", "confidence", "reason_code", "reason"],
      "properties": {
        "label": { "$ref": "#/$defs/bilingual" },
        "state": { "type": "string", "enum": ["healthy", "degraded", "failed", "off"] },
        "source": { "type": "string", "enum": ["sensor", "estimator", "derived", "policy"] },
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "reason_code": { "type": "string" },
        "reason": { "$ref": "#/$defs/bilingual" }
      }
    },
    "proposal": {
      "type": "object",
      "additionalProperties": true,
      "required": ["proposal_id", "title", "justification", "confidence", "priority", "suggested_questions", "proposed_actions"],
      "properties": {
        "proposal_id": { "type": "string" },
        "title": { "$ref": "#/$defs/bilingual" },
        "justification": { "$ref": "#/$defs/bilingual" },
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "priority": { "type": "integer", "minimum": 0, "maximum": 100 },
        "suggested_questions": { "type": "array", "items": { "$ref": "#/$defs/bilingual" } },
        "proposed_actions": { "type": "array", "items": { "$ref": "#/$defs/action" } }
      }
    }
  }
}
